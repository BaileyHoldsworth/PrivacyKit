---
// Optional defaults let the programmatic /password-generator/<preset>/ pages
// preconfigure the generator. The generic tool route passes nothing, so the
// standard page keeps its 20-char, all-sets-on defaults.
interface Props {
  length?: number;
  sets?: { lower: boolean; upper: boolean; numbers: boolean; symbols: boolean };
}
const { length = 20, sets = { lower: true, upper: true, numbers: true, symbols: true } } = Astro.props;
---

<div class="tool" data-tool="password-generator">
  <div class="pane-group">
    <div class="pane-toolbar">
      <span class="pane-label">Generated password</span>
      <div class="pane-actions">
        <button class="btn btn-ghost btn-sm" type="button" data-copy-target="#pg-output">Copy</button>
      </div>
    </div>
    <input
      id="pg-output"
      class="pane pane-mono"
      type="text"
      readonly
      aria-label="Generated password"
      placeholder="Choose options below, then generate"
      autocomplete="off"
      spellcheck="false"
    />
  </div>

  <div class="field">
    <label for="pg-length">Length: <span id="pg-length-value" class="range-value">{length}</span></label>
    <div class="range-row">
      <input id="pg-length" type="range" min="8" max="128" value={length} />
    </div>
  </div>

  <fieldset class="field" style="border:none;padding:0">
    <legend class="field-hint" style="padding:0 0 var(--s-1)">Character sets</legend>
    <div class="field-row">
      <label class="checkbox-row"><input type="checkbox" id="pg-lowercase" checked={sets.lower} /> Lowercase (a–z)</label>
      <label class="checkbox-row"><input type="checkbox" id="pg-uppercase" checked={sets.upper} /> Uppercase (A–Z)</label>
      <label class="checkbox-row"><input type="checkbox" id="pg-numbers" checked={sets.numbers} /> Numbers (0–9)</label>
      <label class="checkbox-row"><input type="checkbox" id="pg-symbols" checked={sets.symbols} /> Symbols (!@#$…)</label>
      <label class="checkbox-row"><input type="checkbox" id="pg-no-ambiguous" /> Exclude look-alikes (O0Il1)</label>
    </div>
  </fieldset>

  <p id="pg-error" class="field-error" role="alert"></p>

  <div class="action-row">
    <button id="pg-generate" class="btn btn-primary" type="button">Generate new password</button>
  </div>

  <div class="stat-row" aria-live="polite">
    <div class="stat">
      <div class="stat-label">Entropy</div>
      <div class="stat-value"><span id="pg-entropy">–</span> bits</div>
    </div>
    <div class="stat">
      <div class="stat-label">Offline crack time (10¹⁰ guesses/s)</div>
      <div class="stat-value" id="pg-crack-time">–</div>
    </div>
  </div>
</div>

<script src="./client.ts"></script>
