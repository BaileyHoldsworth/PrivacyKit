<div class="tool" data-tool="json-formatter">
  <div class="pane-group">
    <div class="pane-toolbar">
      <label class="pane-label" for="json-input">JSON input</label>
      <div class="pane-actions">
        <button id="json-clear" class="btn btn-ghost btn-sm" type="button">Clear</button>
      </div>
    </div>
    <textarea
      id="json-input"
      class="pane pane-mono"
      rows="10"
      placeholder='Paste JSON — e.g. {"invoice": 4021, "paid": false}'
      spellcheck="false"
      autocomplete="off"
      autocapitalize="off"
    ></textarea>
    <p class="field-hint" id="json-input-count">0 characters</p>
  </div>

  <div class="field-row">
    <div class="field">
      <label for="json-indent">Indentation (Format)</label>
      <select id="json-indent" class="select">
        <option value="2" selected>2 spaces</option>
        <option value="4">4 spaces</option>
      </select>
    </div>
    <label class="checkbox-row"><input type="checkbox" id="json-sort" /> Sort keys A→Z (recursive)</label>
  </div>

  <div class="action-row">
    <button id="json-format" class="btn btn-primary" type="button">Format</button>
    <button id="json-minify" class="btn" type="button">Minify</button>
    <button id="json-validate" class="btn" type="button">Validate</button>
    <span id="json-status" class="badge badge-ok" hidden aria-live="polite"></span>
  </div>

  <p id="json-error" class="field-error" role="alert" aria-live="polite"></p>

  <div class="pane-group">
    <div class="pane-toolbar">
      <label class="pane-label" for="json-output">Output</label>
      <div class="pane-actions">
        <button class="btn btn-ghost btn-sm" type="button" data-copy-target="#json-output">Copy</button>
        <button id="json-download" class="btn btn-ghost btn-sm" type="button">Download</button>
      </div>
    </div>
    <textarea
      id="json-output"
      class="pane pane-mono"
      rows="10"
      readonly
      placeholder="Formatted JSON appears here"
      spellcheck="false"
    ></textarea>
  </div>

  <div class="stat-row" aria-live="polite">
    <div class="stat">
      <div class="stat-label">Object keys</div>
      <div class="stat-value" id="json-stat-keys">–</div>
    </div>
    <div class="stat">
      <div class="stat-label">Max depth</div>
      <div class="stat-value" id="json-stat-depth">–</div>
    </div>
    <div class="stat">
      <div class="stat-label">Size</div>
      <div class="stat-value" id="json-stat-size">–</div>
    </div>
  </div>
</div>

<script src="./client.ts"></script>
