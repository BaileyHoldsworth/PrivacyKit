---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PrivacyBadge from '../components/PrivacyBadge.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import AffiliateBox from '../components/AffiliateBox.astro';
import AdSlot from '../components/AdSlot.astro';
import RelatedTools from '../components/RelatedTools.astro';
import { getCategory } from '../config/categories';
import { softwareApplicationLd, breadcrumbLd } from '../lib/jsonld';

interface Props {
  tool: CollectionEntry<'tools'>;
}

const { tool } = Astro.props;
const t = tool.data;
const slug = tool.id;
const category = getCategory(t.category);
const crumbs = [
  { name: 'Home', path: '/' },
  { name: category.name, path: `/category/${category.slug}/` },
  { name: t.name, path: `/tools/${slug}/` },
];
const jsonLd = [
  softwareApplicationLd({ name: t.name, description: t.description, slug, jsonLdCategory: t.jsonLdCategory }),
  breadcrumbLd(crumbs),
];
---

<BaseLayout
  title={t.title}
  description={t.description}
  path={`/tools/${slug}/`}
  ogImage={`/og/tools/${slug}.png`}
  jsonLd={jsonLd}
>
  <main class="container tool-page">
    <Breadcrumbs crumbs={crumbs} />
    <div class="tool-head">
      <h1>{t.name}</h1>
      <button
        class="fav-btn"
        type="button"
        data-fav-toggle={slug}
        aria-pressed="false"
        aria-label={`Save ${t.name} to your favorites`}
      >
        <svg class="fav-star" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 17.75l-6.172 3.245l1.179 -6.873l-5 -4.867l6.9 -1l3.086 -6.253l3.086 6.253l6.9 1l-5 4.867l1.179 6.873z"/></svg>
        <span class="fav-label">Save</span>
      </button>
    </div>
    <p class="tool-lede">{t.description}</p>
    <PrivacyBadge privacy={t.privacy} apiNote={t.apiNote} />

    {/* The tool itself — above the fold, never preceded by an ad. */}
    <slot name="ui" />

    <article class="prose tool-content">
      <slot name="content" />
    </article>

    <FaqAccordion faqs={t.faqs} />

    {t.affiliateGroup && <AffiliateBox group={t.affiliateGroup} />}
    {t.ads && <AdSlot slot="toolBottom" />}

    <RelatedTools slugs={t.related} />
  </main>

  <script>
    import { initFavoriteToggle, recordVisit } from '../lib/favorites';
    const el = document.querySelector<HTMLElement>('[data-fav-toggle]');
    if (el?.dataset.favToggle) recordVisit(el.dataset.favToggle);
    initFavoriteToggle();
  </script>
</BaseLayout>
