---
import { AFFILIATES } from '../config/affiliates';

interface Props {
  group: 'passwords' | 'vpn' | 'dev';
}
const { group } = Astro.props;
// Only offers with a configured tracking URL render; max two per box.
const offers = AFFILIATES[group].filter((o) => o.url !== '').slice(0, 2);

// Per-page sub-ID: identifies which page a click came from so the affiliate
// network's dashboard reports earnings per page (no cookies, no first-party
// tracking code). e.g. "/tools/password-generator/" -> "tools-password-generator".
const subId = Astro.url.pathname.replace(/^\/|\/$/g, '').replace(/\//g, '-') || 'home';

function withSubId(url: string, param = 'u1'): string {
  const sep = url.includes('?') ? '&' : '?';
  return `${url}${sep}${param}=${encodeURIComponent(subId)}`;
}
---

{offers.length > 0 && (
  <aside class="affiliate-box" aria-label="Recommended services">
    <p class="affiliate-kicker">Recommended</p>
    {offers.map((o) => (
      <div class="affiliate-offer">
        <div class="affiliate-copy">
          <strong>{o.name}</strong>
          <p>{o.blurb}</p>
        </div>
        <a
          class="btn btn-primary"
          href={withSubId(o.url, o.subIdParam)}
          rel="sponsored noopener"
          target="_blank"
        >{o.cta}</a>
      </div>
    ))}
    <p class="affiliate-disclosure">
      Disclosure: if you sign up through a link above, PrivacyKit earns a commission at no extra
      cost to you. See our <a href="/affiliate-disclosure/">affiliate disclosure</a>.
    </p>
  </aside>
)}
