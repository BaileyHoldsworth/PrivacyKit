---
import ThemeToggle from './ThemeToggle.astro';
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="PrivacyKit home">
      <span class="logo-mark" aria-hidden="true">⬡</span>
      <span class="logo-text">PrivacyKit</span>
    </a>
    <nav class="site-nav" aria-label="Main">
      <a href="/tools/">Tools</a>
      <a href="/guides/">Guides</a>
      <a href="/about/">About</a>
    </nav>
    <div class="header-actions">
      <button class="search-trigger" data-open-palette type="button" aria-label="Search tools (Ctrl+K)">
        <span class="search-trigger-label">Search tools…</span>
        <kbd>⌘K</kbd>
      </button>
      <ThemeToggle />
    </div>
  </div>
</header>
