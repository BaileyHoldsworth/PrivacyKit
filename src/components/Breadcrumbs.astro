---
interface Props {
  crumbs: { name: string; path: string }[];
}
const { crumbs } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol>
    {crumbs.map((c, i) => (
      <li>
        {i < crumbs.length - 1 ? (
          <>
            <a href={c.path}>{c.name}</a>
            <span class="crumb-sep" aria-hidden="true">/</span>
          </>
        ) : (
          <span aria-current="page">{c.name}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
